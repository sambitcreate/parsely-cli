{
  "name": "@sambitcreate/parsely-cli",
  "version": "2.0.0",
  "description": "A smart recipe scraper CLI with interactive TUI built on Ink",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "parsely": "dist/cli.js"
  },
  "scripts": {
    "start": "tsx src/cli.tsx",
    "dev": "tsx watch src/cli.tsx",
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test": "tsx --test test/**/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "recipe",
    "scraper",
    "cli",
    "tui",
    "ink",
    "terminal"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "public",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sambitcreate/parsely-cli.git"
  },
  "bugs": {
    "url": "https://github.com/sambitcreate/parsely-cli/issues"
  },
  "homepage": "https://github.com/sambitcreate/parsely-cli#readme",
  "dependencies": {
    "cheerio": "^1.0.0",
    "cfonts": "^3.1.1",
    "dotenv": "^16.4.7",
    "ink": "^5.1.0",
    "ink-big-text": "^2.0.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "openai": "^4.82.0",
    "puppeteer-core": "^24.2.1",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/ink-big-text": "^1.2.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "packageManager": "pnpm@10.28.1+sha512.7d7dbbca9e99447b7c3bf7a73286afaaf6be99251eb9498baefa7d406892f67b879adb3a1d7e687fc4ccc1a388c7175fbaae567a26ab44d1067b54fcb0d6a316"
}
