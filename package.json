{
  "name": "parsely-cli",
  "version": "2.0.0",
  "description": "A smart recipe scraper CLI with interactive TUI built on Ink",
  "type": "module",
  "main": "src/cli.tsx",
  "bin": {
    "parsely": "src/cli.tsx"
  },
  "scripts": {
    "start": "tsx src/cli.tsx",
    "dev": "tsx watch src/cli.tsx",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "recipe",
    "scraper",
    "cli",
    "tui",
    "ink",
    "terminal"
  ],
  "license": "MIT",
  "dependencies": {
    "ink": "^5.1.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^18.3.1",
    "puppeteer-core": "^24.2.1",
    "openai": "^4.82.0",
    "cheerio": "^1.0.0",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "tsx": "^4.19.2",
    "@types/react": "^18.3.18"
  }
}
